  if (words.length < 2 || words.length > 8) return null;
  const tags = detectGroupTags(text);
  if (!tags.length) return null;
  const name = words[0];
  return {
    name,
    status: STATUS_PENDING,
    category: tags.join(", "),
    side: detectSide(text),
    dietary: "ללא",
    table: 0,
    notes: tags.length > 1 ? `קבוצות: ${tags.join(", ")}` : "",
  };
}

