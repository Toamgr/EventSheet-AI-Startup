    category: detectSupplierCategory(text),
    name: cleanupLabel(text.replace(/\d[\d,.\s]*/g, "")) || text,
    amount,
    paid,
    status: /שולם/i.test(text) ? "שולמה מקדמה" : "יתרה להסדרה",
  };
